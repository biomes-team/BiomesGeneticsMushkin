    <AbilityDef ParentName="AbilityTouchBase">
        <defName>BGM_ResurrectionMycelia</defName>
        <label>resurrection mycelia</label>
        <description>Resurrect a fresh corpse with an invasive fungal growth. It does not always work out very well, however.</description>
