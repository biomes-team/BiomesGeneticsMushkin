<?xml version="1.0" encoding="UTF-8"?>
<Defs>

  <BiomesCore.Defs.BMT_GeneDef ParentName="BMT_MushkinGenes_Base">
	<defName>BGM_FirefoamSpores</defName>
	<label>firefoam spores</label>
	<geneClass>BiomesGeneticsMushkin.MushkinGene</geneClass>
	<description>The unique fungi within the host makes them capable of producing a cone of fire-suppressent fungal spores from specialized organs.</description>
	<iconPath>UI/Ability-Genes/Firefoam_Spores</iconPath>
	<displayCategory>SporesFungal</displayCategory>
	<displayOrderInCategory>-1</displayOrderInCategory>
	<prerequisite>BGM_FungalSymbiosis</prerequisite>
	<abilities>
		<li>BGM_FirefoamSpores</li>
	</abilities>
	<descriptionHyperlinks>
		<AbilityDef>BGM_FirefoamSpores</AbilityDef>
	</descriptionHyperlinks>
	<biostatMet>-2</biostatMet>
	<biostatCpx>1</biostatCpx>
  </BiomesCore.Defs.BMT_GeneDef>

  <!-- ======================== -->

  <AbilityDef>
	<defName>BGM_FirefoamSpores</defName>
	<label>foam spores</label>
	<description>Spray thick fire-retardant foam from specialized gills in the fungal cap. The foam will cover a small area and extinguish any fire it touches.</description>
	<iconPath>UI/Ability-Genes/Firefoam_Spores</iconPath>
	<charges>2</charges>
	<cooldownTicksRange>30000</cooldownTicksRange><!-- 1/2 day -->
	<warmupStartSound>FoamSpray_Warmup</warmupStartSound>
	<hostile>false</hostile>
	<sendMessageOnCooldownComplete>true</sendMessageOnCooldownComplete>
	<casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
	<verbProperties>
		<verbClass>Verb_CastAbility</verbClass>
		<range>8.9</range>
		<warmupTime>1</warmupTime>
		<soundCast>FoamSpray_Resolve</soundCast>
		<targetParams>
			<canTargetLocations>true</canTargetLocations>
		</targetParams>
	</verbProperties>
	<comps>
		<li Class="CompProperties_AbilitySprayLiquid">
			<projectileDef>Proj_Foam_Ability</projectileDef>
			<numCellsToHit>12</numCellsToHit>
			<sprayEffecter>FoamSpray_Directional</sprayEffecter>
		</li>
	</comps>
  </AbilityDef>

</Defs>