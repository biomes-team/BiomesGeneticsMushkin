<?xml version="1.0" encoding="UTF-8"?>
<Defs>

  <BiomesCore.Defs.BMT_GeneDef ParentName="BMT_MushkinGenes_Base">
	<defName>BGM_PsySpores</defName>
	<label>psy spores</label>
	<geneClass>BiomesGeneticsMushkin.MushkinGene</geneClass>
	<description>The unique fungi within the host allows them to produce a puff of fungal spores from specialized organs that enhance the psychic sensitivity of those affected.</description>
	<iconPath>UI/Ability-Genes/Psy_Spores</iconPath>
	<displayCategory>SporesFungal</displayCategory>
	<displayOrderInCategory>-1</displayOrderInCategory>
	<prerequisite>BGM_FungalSymbiosis</prerequisite>
	<abilities>
		<li>BGM_PsySpores</li>
	</abilities>
	<descriptionHyperlinks>
		<AbilityDef>BGM_PsySpores</AbilityDef>
	</descriptionHyperlinks>
	<biostatMet>-2</biostatMet>
	<biostatCpx>1</biostatCpx>
  </BiomesCore.Defs.BMT_GeneDef>

