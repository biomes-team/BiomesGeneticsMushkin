<?xml version="1.0" encoding="UTF-8"?>
<Defs>

  <BiomesCore.Defs.BMT_GeneDef ParentName="BMT_MushkinGenes_Base">
	<defName>BGM_InfectiousMycelia</defName>
	<label>infectious mycelia</label>
	<geneClass>BiomesGeneticsMushkin.MushkinGene</geneClass>
	<description>The unique fungi within the host allows them to spread it into new hosts via mycelium, where it bonds with their body on a cellular level.</description>
	<iconPath>UI/Ability-Genes/Infectious_Spores</iconPath>
	<displayCategory>SporesFungal</displayCategory>
	<displayOrderInCategory>-1</displayOrderInCategory>
	<prerequisite>BGM_FungalSymbiosis</prerequisite>
	<abilities>
		<li>BGM_InfectiousMycelia</li>
	</abilities>
	<descriptionHyperlinks>
		<AbilityDef>BGM_InfectiousMycelia</AbilityDef>
	</descriptionHyperlinks>
	<biostatMet>-2</biostatMet>
	<biostatCpx>1</biostatCpx>
  </BiomesCore.Defs.BMT_GeneDef>

  <!-- ======================== -->

  <AbilityDef ParentName="AbilityTouchBase">
	<defName>BGM_InfectiousMycelia</defName>
	<label>infectious mycelia</label>
	<description>The user extends fungal mycelia into another human, seeding the fungus within them and turning them into a mushkin.</description>
	<iconPath>UI/Ability-Genes/Infectious_Spores</iconPath>
	<cooldownTicksRange>600000</cooldownTicksRange><!-- 10 days -->
	<hostile>false</hostile>
	<jobDef>CastAbilityOnThingMelee</jobDef>
	<casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
	<displayGizmoWhileUndrafted>true</displayGizmoWhileUndrafted>
	<disableGizmoWhileUndrafted>false</disableGizmoWhileUndrafted>
	<showWhenDrafted>false</showWhenDrafted>
	<verbProperties>
		<verbClass>Verb_CastAbilityTouch</verbClass>
		<drawAimPie>false</drawAimPie>
		<range>-1</range>
		<warmupTime>4</warmupTime>
		<targetParams>
			<canTargetBuildings>false</canTargetBuildings>
			<canTargetAnimals>false</canTargetAnimals>
			<canTargetMechs>false</canTargetMechs>
			<canTargetEntities>false</canTargetEntities>
		</targetParams>
	</verbProperties>
	<comps>
		<li Class="BiomesGeneticsMushkin.CompProperties_InfectiousSpores">
			<xenotypeToTransform>BGM_Mushkin</xenotypeToTransform>
			<geneOverriddenByParasitism>BGM_BaseCap</geneOverriddenByParasitism> <!-- Dummy -->
			<parasitismGene>BGM_FungalParasitism</parasitismGene>
			<hediffDef>BMT_SpreadingMycelia</hediffDef>
			<parasitismChance>0.1</parasitismChance>
		</li>
		<!-- <li Class = "CompProperties_AbilityGiveHediff"> -->
			<!-- <compClass>CompAbilityEffect_GiveHediff</compClass> -->
			<!-- <hediffDef>BMT_SpreadingMycelia</hediffDef> -->
			<!-- <applicableToMechs>False</applicableToMechs> -->
		<!-- </li> -->
	</comps>
  </AbilityDef>

</Defs>