<?xml version="1.0" encoding="UTF-8"?>
<Defs>

  <BiomesCore.Defs.BMT_GeneDef ParentName="BMT_MushkinGenes_Base">
	<defName>BGM_PsyNegatingSpores</defName>
	<label>psy-negating spores</label>
	<geneClass>BiomesGeneticsMushkin.MushkinGene</geneClass>
	<description>The unique fungi within the host allows them to produce a puff of fungal spores from specialized organs that drastically dull the psychic sensitivity of those affected.</description>
	<iconPath>UI/Ability-Genes/PsyNegation_Spores</iconPath>
	<displayCategory>SporesFungal</displayCategory>
	<displayOrderInCategory>-1</displayOrderInCategory>
	<prerequisite>BGM_FungalSymbiosis</prerequisite>
	<abilities>
		<li>BGM_PsyNegationSpores</li>
	</abilities>
	<descriptionHyperlinks>
		<AbilityDef>BGM_PsyNegationSpores</AbilityDef>
	</descriptionHyperlinks>
	<biostatMet>-2</biostatMet>
	<biostatCpx>1</biostatCpx>
  </BiomesCore.Defs.BMT_GeneDef>

  <!-- ======================== -->

  <AbilityDef ParentName="BGM_GeneAbility_HediffGivingSpores">
