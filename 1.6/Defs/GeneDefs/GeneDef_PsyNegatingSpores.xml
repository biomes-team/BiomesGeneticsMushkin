	<label>psy-negating spores</label>
	<description>Produce a puff of spores from specialized organs that deafen the psychic sensitivity of those intaking it.</description>
	<iconPath>UI/Ability-Genes/PsyNegation_Spores</iconPath>
	<cooldownTicksRange>300000</cooldownTicksRange><!-- 5 days -->
	<comps>
		<li Class="BiomesGeneticsMushkin.CompProperties_HediffGiverArea">
			<hediffDef>BGM_PsyNegationSpores</hediffDef>
			<range>10</range>
			<effecter>BGM_SporePuff</effecter>
			<xenotypesImmuneToDebuff />
		</li>
