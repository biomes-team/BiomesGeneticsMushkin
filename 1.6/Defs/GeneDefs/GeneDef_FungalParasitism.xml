<?xml version="1.0" encoding="UTF-8"?>
<Defs>

  <BiomesCore.Defs.BMT_GeneDef ParentName="BMT_MushkinGenes_Base">
	<defName>BGM_FungalParasitism</defName>
	<label>fungal parasitism</label>
	<description>The unique fungi within the host has formed a parasitic bond instead of a symbiotic one, slowly devouring the host for sustenance. The spreading mycelia within the body tends to cause increasingly negative conditions, eventually leading to death. It does however have the positive side effects of disabling pain and extending the physical limits of the host. Their gradually degrading condition can be attenuated but not ceased with periodic medical care.</description>
	<geneClass>BiomesGeneticsMushkin.Gene_FungalParasitism</geneClass>
	<iconPath>UI/Genes/Gene_FungalParasitism</iconPath>
	<displayCategory>Fungal</displayCategory>
	<displayOrderInCategory>40</displayOrderInCategory>
	<aggroMentalBreakSelectionChanceFactor>999</aggroMentalBreakSelectionChanceFactor>
	<abilities>
		<li>BGM_FungalParasitism</li>
	</abilities>
	<descriptionHyperlinks>
		<AbilityDef>BGM_FungalParasitism</AbilityDef>
	</descriptionHyperlinks>
	<biostatMet>-5</biostatMet>
	<biostatCpx>1</biostatCpx>
	<painFactor>0</painFactor>
	<statFactors>
		<LifespanFactor>0.6</LifespanFactor>
		<CancerRate>5</CancerRate>
		<ImmunityGainSpeed>0.92</ImmunityGainSpeed>
		<MeleeDamageFactor>1.5</MeleeDamageFactor>
		<CarryingCapacity>1.25</CarryingCapacity>
	</statFactors>
	<symbolPack>
		<wholeNameSymbols>
			<li>
				<symbol>parasitic</symbol>
			</li>
		</wholeNameSymbols>
		<prefixSymbols>
			<li>
				<symbol>infected</symbol>
			</li>
			<li>
				<symbol>infested</symbol>
			</li>
			<li>
				<symbol>parasite</symbol>
			</li>
		</prefixSymbols>
		<suffixSymbols>
			<li>
				<symbol>host</symbol>
			</li>
		</suffixSymbols>
	</symbolPack>
  </BiomesCore.Defs.BMT_GeneDef>

