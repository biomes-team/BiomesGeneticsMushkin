<?xml version="1.0" encoding="UTF-8"?>
<Defs>

  <BiomesCore.Defs.BMT_GeneDef ParentName="BMT_MushkinGenes_Base">
	<defName>BGM_CasteSwap</defName>
	<label>caste swap</label>
	<geneClass>BiomesGeneticsMushkin.MushkinGene</geneClass>
	<description>The fungus within this host allows them to manipulate the fungus within others, changing the way it is expressed in their body.</description>
	<iconPath>UI/Ability-Genes/CasteSwap</iconPath>
	<displayCategory>Fungal</displayCategory>
	<displayOrderInCategory>-1</displayOrderInCategory>
	<prerequisite>BGM_FungalSymbiosis</prerequisite>
	<abilities>
		<li>BGM_CasteSwap</li>
	</abilities>
	<descriptionHyperlinks>
		<AbilityDef>BGM_CasteSwap</AbilityDef>
	</descriptionHyperlinks>
	<biostatMet>-1</biostatMet>
	<biostatCpx>1</biostatCpx>
  </BiomesCore.Defs.BMT_GeneDef>

  <!-- ======================== -->

  <AbilityDef ParentName="AbilityTouchBase">
	<defName>BGM_CasteSwap</defName>
	<label>caste swap</label>
	<description>The dominant strain of fungi within the user allows them to alter the expression of the fungi within others.</description>
	<iconPath>UI/Ability-Genes/CasteSwap</iconPath>
	<cooldownTicksRange>180000</cooldownTicksRange><!-- 1 day -->
	<hostile>false</hostile>
	<jobDef>CastAbilityOnThingMelee</jobDef>
	<casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
	<displayGizmoWhileUndrafted>true</displayGizmoWhileUndrafted>
	<disableGizmoWhileUndrafted>false</disableGizmoWhileUndrafted>
	<showWhenDrafted>false</showWhenDrafted>
	<verbProperties>
		<verbClass>Verb_CastAbilityTouch</verbClass>
		<drawAimPie>false</drawAimPie>
		<range>-1</range>
		<warmupTime>1</warmupTime>
		<targetParams>
			<canTargetBuildings>false</canTargetBuildings>
			<canTargetAnimals>false</canTargetAnimals>
			<canTargetMechs>false</canTargetMechs>
			<canTargetEntities>false</canTargetEntities>
		</targetParams>
	</verbProperties>
	<comps>
		<li Class="BiomesGeneticsMushkin.CompProperties_CasteSwap">
			<hediffToGive>BGM_SwitchCasteExhaustion</hediffToGive>
			<parasitismGene>BGM_FungalParasitism</parasitismGene>
			<allowedXenotypes>
				<li>BGM_Mushkin</li>
				<li>BGM_Tallcap</li>
				<li>BGM_Necrospore</li>
				<li>BGM_Ironcap</li>
				<li>BGM_Patchphae</li>
			</allowedXenotypes>
		</li>
	</comps>
  </AbilityDef>

</Defs>