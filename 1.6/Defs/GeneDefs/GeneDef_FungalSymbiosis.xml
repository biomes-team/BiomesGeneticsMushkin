<Defs>

  <BiomesCore.Defs.BMT_GeneDef ParentName="BMT_MushkinGenes_Base">
	<defName>BGM_FungalSymbiosis</defName>
	<label>fungal symbiosis</label>
	<description>The unique fungi within the host forms a symbiotic bond and is similar in nature to cordyceps, albeit a variant that has been designed to work with the human body. It grants them increased metabolism thanks to the fungus helping reduce waste chemicals and wasted nutrients in the host. This connection also grants a simple psychic connection to others with the same condition.</description>
	<geneClass>BiomesGeneticsMushkin.Gene_FungalSymbiosis</geneClass>
	<iconPath>UI/Genes/Gene_FungalSymbiosis</iconPath>
	<displayCategory>CoreFungal</displayCategory>
	<displayOrderInCategory>50</displayOrderInCategory>
	<deathHistoryEvent>BGM_FungalSymbiosisDied</deathHistoryEvent>
	<forcedTraits>
		<li>
			<def>Undergrounder</def>
		</li>
	</forcedTraits>
	<biostatMet>6</biostatMet>
	<biostatCpx>2</biostatCpx>
	<symbolPack>
