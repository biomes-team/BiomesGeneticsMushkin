			<li>
				<symbol>fungal</symbol>
			</li>
		</wholeNameSymbols>
		<prefixSymbols>
			<li>
				<symbol>mush</symbol>
			</li>
			<li>
				<symbol>fungi</symbol>
			</li>
			<li>
				<symbol>mycelial</symbol>
			</li>
		</prefixSymbols>
		<suffixSymbols>
			<li>
				<symbol>mushroom</symbol>
			</li>
			<li>
				<symbol>fungus</symbol>
			</li>
			<li>
