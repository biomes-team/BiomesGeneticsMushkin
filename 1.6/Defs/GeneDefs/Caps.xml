<Defs>

  <BiomesCore.Defs.BMT_GeneDef ParentName="GeneHairStyleBase" Name="BMT_MushkinGenes_GeneHairStyleBase" Abstract="True">
	<backgroundPath>UI/Xenotype/GeneBackground_Mushkin</backgroundPath>
	<geneClass>BiomesGeneticsMushkin.MushkinGene</geneClass>
    <displayCategory>Fungal</displayCategory>
	<displayOrderInCategory>55</displayOrderInCategory>
	<hairTagFilter>
		<whitelist>true</whitelist>
		<tags>
			<li>Bald</li>
		</tags>
	</hairTagFilter>
	<symbolPack>
		<prefixSymbols>
			<li>
				<symbol>crop</symbol>
			</li>
			<li>
				<symbol>fuzz</symbol>
			</li>
			<li>
				<symbol>stub</symbol>
			</li>
			<li>
				<symbol>patch</symbol>
			</li>
		</prefixSymbols>
		<suffixSymbols>
			<li>
				<symbol>crop</symbol>
			</li>
			<li>
				<symbol>fuzz</symbol>
			</li>
			<li>
				<symbol>stub</symbol>
			</li>
			<li>
				<symbol>patch</symbol>
			</li>
		</suffixSymbols>
	</symbolPack>
  </BiomesCore.Defs.BMT_GeneDef>


    <BiomesCore.Defs.BMT_GeneDef ParentName="BMT_MushkinGenes_GeneHairStyleBase">
        <defName>BGM_BaseCap</defName>
        <label>mushroom cap</label>
        <labelShortAdj>mushroom cap</labelShortAdj>
        <description>The fungus that grants this gene makes the carrier grow a simple mushroom cap in place of hair.</description>
        <iconPath>UI/Genes/Gene_BaseCap</iconPath>
		<displayCategory>Fungal</displayCategory>
		<displayOrderInCategory>55.0</displayOrderInCategory>
        <renderNodeProperties>
            <li>
                <nodeClass>PawnRenderNode_AttachmentHead</nodeClass>
                <workerClass>PawnRenderNodeWorker_FlipWhenCrawling</workerClass>
                <texPath>Things/Pawn/Humanlike/HeadAttachments/Base/Base</texPath>
                <colorType>Hair</colorType>
                <parentTagDef>Head</parentTagDef>
                <useSkinShader>false</useSkinShader>
                <useRottenColor>true</useRottenColor>
                <rotDrawMode>Fresh, Rotting</rotDrawMode>
				<baseLayer>70</baseLayer>
				<!-- <skipFlag>Hair</skipFlag> -->
                <!-- <drawData> -->
                    <!-- <defaultData> -->
                        <!-- <layer>70</layer> -->
                    <!-- </defaultData> -->
                <!-- </drawData> -->
            </li>
        </renderNodeProperties>
    </BiomesCore.Defs.BMT_GeneDef>

